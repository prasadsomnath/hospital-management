{
  "name": "hospital-management-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && pnpm copy:env",
    "copy:env": "shx cp env.json dist/",
    "typecheck": "tsc --noEmit",
    "check": "biome check src",
    "fix": "biome check --write src",
    "desktop:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development ELECTRON=true electron .\"",
    "desktop:build": "cross-env ELECTRON=true vite build && pnpm copy:env && electron-builder"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@dfinity/agent": "~3.3.0",
    "@dfinity/auth-client": "~3.3.0",
    "@dfinity/candid": "~3.3.0",
    "@dfinity/identity": "~3.3.0",
    "@dfinity/principal": "~3.3.0",
    "@icp-sdk/core": "~4.1.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@react-three/cannon": "~6.6.0",
    "@react-three/drei": "~10.0.8",
    "@react-three/fiber": "~9.1.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "0.5.10",
    "@tanstack/react-query": "^5.24.0",
    "@tanstack/react-router": "~1.131.8",
    "@types/node": "^20.9.0",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "@types/three": "0.176.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^8.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.2.1",
    "input-otp": "^1.4.1",
    "lucide-react": "0.511.0",
    "motion": "^12.34.3",
    "next-themes": "~0.4.6",
    "postcss": "^8.4.41",
    "react": "~19.1.0",
    "react-day-picker": "^9.5.0",
    "react-dom": "~19.1.0",
    "react-hook-form": "^7.53.0",
    "react-icons": "^5.4.0",
    "react-quill-new": "3.4.6",
    "react-resizable-panels": "^2.1.7",
    "react-use": "~17.6.0",
    "recharts": "^2.15.1",
    "shx": "^0.4.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.176.0",
    "typescript": "^5.8.3",
    "vaul": "^1.1.2",
    "vite": "^5.4.1",
    "vite-plugin-environment": "^1.1.3",
    "wait-on": "^9.0.10",
    "zustand": "~5.0.5"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.skyllx.healthmatrix360",
    "productName": "HealthMatrix360",
    "directories": {
      "output": "desktop-build"
    },
    "files": [
      "dist/**/*",
      "!desktop-build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.healthcare-fitness"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    }
  }
}
